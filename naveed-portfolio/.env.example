# ── AI Configuration ───────────────────────────────
# Set VITE_AI_PROVIDER to enable the chat widget.
# Options: openai | langchain | none

VITE_AI_PROVIDER=none

# ── OpenAI Direct ──────────────────────────────────
VITE_OPENAI_API_KEY=
VITE_OPENAI_BASE_URL=https://api.openai.com/v1
VITE_AI_MODEL=gpt-4o-mini

# ── LangChain Backend ──────────────────────────────
# Point this to your LangChain backend (e.g. FastAPI + LangServe)
VITE_LANGCHAIN_ENDPOINT=
